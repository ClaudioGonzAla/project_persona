# ─── Cloud LLM APIs ───────────────────────────────────────────────────────────
GEMINI_API_KEY='your_gemini_api_key_here'
OPENAI_API_KEY='your_openai_api_key_here'
ANTHROPIC_API_KEY='your_anthropic_api_key_here'

# ─── Local Llama 8B (LM Studio) ───────────────────────────────────────────────
# Default endpoint — change host/port if LM Studio is on a different machine.
LLAMA_BASE_URL=http://localhost:1234/v1
LLAMA_API_KEY=lm-studio
LLAMA_TUNED_8B_ID=llama-3.1-swallow-8b-instruct-v0.2-i1
LLAMA_BASE_8B_ID=meta-llama-3.1-8b-instruct

# ─── Lab server 70B ───────────────────────────────────────────────────────────
# Set these when running 70B models on a separate server.
# If LLAMA_70B_BASE_URL is not set, the 8B endpoint above is used as fallback.
LLAMA_70B_BASE_URL=http://<server-host>:<port>/v1
LLAMA_70B_API_KEY='your_llama_70b_api_key_here'
LLAMA_TUNED_70B_ID=llama-3.1-swallow-70b-instruct-v0.x
LLAMA_BASE_70B_ID=meta-llama-3.3-70b-instruct
